+
+SYM_INNER_LABEL(pvm_restore_regs_and_return_to_usermode, SYM_L_GLOBAL)
+	STACKLEAK_ERASE
+	POP_REGS_AND_LOAD_IRET_FRAME_INTO_PVCS
