+static bool detect_cpuid_la57(void)
+{
+#ifdef CONFIG_PVM_GUEST
+	if (pvm_detected) {
+		u32 eax, ebx, ecx, edx;
+
+		eax = 0;
+		pvm_cpuid(&eax, &ebx, &ecx, &edx);
+		if (eax >= 7) {
+			eax = 7;
+			ecx = 0;
+			pvm_cpuid(&eax, &ebx, &ecx, &edx);
+			if (ecx & (1 << (X86_FEATURE_LA57 & 31)))
+				return true;
+		}
+		return false;
+	}
