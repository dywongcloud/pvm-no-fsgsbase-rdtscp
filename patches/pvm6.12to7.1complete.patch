+	ja	.L_pvm_supervisor_iret_irq_fixed
+
+	// if RIP >= .L_pvm_supervisor_iret_irq_enabled_end ==> skip fixup
+	leaq	.L_pvm_supervisor_iret_irq_enabled_end(%rip), %rcx
+	cmpq	RIP-RIP(%rsp), %rcx
+	jbe	.L_pvm_supervisor_iret_irq_fixed
+
